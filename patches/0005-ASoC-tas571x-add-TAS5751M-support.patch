From 32363a07e015a4a692627cf1a3a066065085030e Mon Sep 17 00:00:00 2001
From: TC8 Mainline Port <tc8@polycom-re.local>
Date: Fri, 8 May 2026 19:53:39 +0000
Subject: [PATCH 5/6] ASoC: tas571x: add TAS5751M support

The TAS5751M is a 2.1 closed-loop class-D amplifier used on the
Polycom TC8 panel.  It is broadly register-compatible with the
TAS5717 (2-byte volume registers, same regmap layout) but its DSP
and BD-modulation routing leave the chip muted at I2S level until
a board-specific init sequence runs.

This patch:

  - Adds a .init() callback to struct tas571x_chip and invokes it
    from tas571x_i2c_probe() right after the post-power-on settle
    delay.
  - Adds tas5751_chip with vol_reg_size=2 (same as tas5717_chip)
    and a tas5751_init() callback that replays the stock Polycom
    register sequence (proline_3106 recipe).  The sequence covers
    SYS_CTRL_1, SDI, master/channel volumes, modulation limit,
    inter-channel delays, BD-mode INPUT_MUX, PWM_OUT_MUX, and DRC
    unity coefficients.
  - Wires up the new "ti,tas5751" of-match and i2c id table
    entry.

The init sequence is documented externally
(re/proline_3106_recipe.md) and is the minimum that produces audible
output through the panel speaker; it is not a full TAS5751M tuning.
---
 sound/soc/codecs/tas571x.c | 74 ++++++++++++++++++++++++++++++++++++++
 1 file changed, 74 insertions(+)

diff --git a/sound/soc/codecs/tas571x.c b/sound/soc/codecs/tas571x.c
index 1756edb35..5f847655e 100644
--- a/sound/soc/codecs/tas571x.c
+++ b/sound/soc/codecs/tas571x.c
@@ -33,6 +33,8 @@
 
 #define TAS571X_MAX_SUPPLIES		6
 
+struct tas571x_private;
+
 struct tas571x_chip {
 	const char			*const *supply_names;
 	int				num_supply_names;
@@ -40,6 +42,7 @@ struct tas571x_chip {
 	int				num_controls;
 	const struct regmap_config	*regmap_config;
 	int				vol_reg_size;
+	int				(*init)(struct tas571x_private *priv);
 };
 
 struct tas571x_private {
@@ -785,6 +788,67 @@ static const struct tas571x_chip tas5721_chip = {
 	.vol_reg_size			= 1,
 };
 
+/* ----- TAS5751M (Polycom TC8 panel) — stock proline_3106 init recipe -----
+ * Extracted from stock kernel by reverse-engineering. The TAS5751M has DSP
+ * and BD-modulation routing that mainline tas5721_chip doesn't configure,
+ * which leaves the chip in a state where I2S data flows but PWM output is
+ * mute. Apply the full stock register sequence here.
+ */
+static int tas5751_init(struct tas571x_private *priv)
+{
+	int ret;
+
+	/* Mute + standby */
+	regmap_write(priv->regmap, TAS571X_SOFT_MUTE_REG, 0x07);
+	regmap_write(priv->regmap, TAS571X_SYS_CTRL_2_REG, 0x40);
+
+	/* Stock single-byte sequence */
+	regmap_write(priv->regmap, 0x03, 0xA0);  /* SYS_CTRL_1: I2S 24-bit */
+	regmap_write(priv->regmap, 0x04, 0x05);  /* SDI: 24-bit */
+	regmap_write(priv->regmap, 0x07, 0x10);  /* MASTER_VOL upper byte */
+	regmap_write(priv->regmap, 0x08, 0xC0);  /* CH1_VOL = 0 dB unity */
+	regmap_write(priv->regmap, 0x09, 0xC0);  /* CH2_VOL = 0 dB unity */
+	regmap_write(priv->regmap, 0x0A, 0xC0);  /* CH3_VOL */
+	regmap_write(priv->regmap, 0x0E, 0xF0);  /* VOL_CFG fade */
+	regmap_write(priv->regmap, 0x10, 0x01);  /* MOD_LIMIT 98.4% */
+	regmap_write(priv->regmap, 0x11, 0xB8);  /* ICD CH1 BD mode */
+	regmap_write(priv->regmap, 0x12, 0x60);  /* ICD CH2 */
+	regmap_write(priv->regmap, 0x13, 0xA0);  /* ICD CH3 */
+	regmap_write(priv->regmap, 0x14, 0x48);  /* ICD CH4 */
+	regmap_write(priv->regmap, 0x19, 0x3A);  /* PWM short-circuit cfg */
+	regmap_write(priv->regmap, 0x1A, 0x68);  /* START_STOP_PERIOD */
+	regmap_write(priv->regmap, 0x1B, 0xC0);  /* OSC_TRIM factory */
+	regmap_write(priv->regmap, 0x1C, 0x57);  /* BKND_ERR */
+
+	/* Stock 4-byte sequence */
+	regmap_write(priv->regmap, 0x20, 0x00897772); /* INPUT_MUX (BD mode) */
+	regmap_write(priv->regmap, 0x25, 0x01002245); /* PWM_OUT_MUX (board-specific) */
+	regmap_write(priv->regmap, 0x4F, 0x00000008); /* PWM_RATE */
+	regmap_write(priv->regmap, 0x50, 0x0F708000); /* OUT_MIX_CH1_A */
+	regmap_write(priv->regmap, 0x46, 0x00020620); /* AGL */
+	regmap_write(priv->regmap, 0x72, 0x00800000); /* DRC1_AB unity */
+	regmap_write(priv->regmap, 0x73, 0x00800000); /* DRC1_CD unity */
+	regmap_write(priv->regmap, 0x76, 0x00800000); /* DRC2_AB unity */
+	regmap_write(priv->regmap, 0x77, 0x00800000); /* DRC2_CD unity */
+
+	/* Exit standby + un-mute */
+	regmap_write(priv->regmap, TAS571X_SYS_CTRL_2_REG, 0x00);
+	regmap_write(priv->regmap, TAS571X_SOFT_MUTE_REG, 0x00);
+
+	(void)ret;
+	return 0;
+}
+
+static const struct tas571x_chip tas5751_chip = {
+	.supply_names			= tas5721_supply_names,
+	.num_supply_names		= ARRAY_SIZE(tas5721_supply_names),
+	.controls			= tas5717_controls,           /* 2-byte vol controls */
+	.num_controls			= ARRAY_SIZE(tas5717_controls),
+	.regmap_config			= &tas5717_regmap_config,    /* 2-byte vol regs */
+	.vol_reg_size			= 2,
+	.init				= tas5751_init,
+};
+
 static const struct snd_soc_dapm_widget tas571x_dapm_widgets[] = {
 	SND_SOC_DAPM_DAC("DACL", NULL, SND_SOC_NOPM, 0, 0),
 	SND_SOC_DAPM_DAC("DACR", NULL, SND_SOC_NOPM, 0, 0),
@@ -913,6 +977,14 @@ static int tas571x_i2c_probe(struct i2c_client *client)
 
 	usleep_range(50000, 60000);
 
+	if (priv->chip->init) {
+		ret = priv->chip->init(priv);
+		if (ret) {
+			dev_err(dev, "chip init failed: %d\n", ret);
+			goto disable_regs;
+		}
+	}
+
 	memcpy(&priv->component_driver, &tas571x_component, sizeof(priv->component_driver));
 	priv->component_driver.controls = priv->chip->controls;
 	priv->component_driver.num_controls = priv->chip->num_controls;
@@ -954,6 +1026,7 @@ static const struct of_device_id tas571x_of_match[] __maybe_unused = {
 	{ .compatible = "ti,tas5717", .data = &tas5717_chip, },
 	{ .compatible = "ti,tas5719", .data = &tas5717_chip, },
 	{ .compatible = "ti,tas5721", .data = &tas5721_chip, },
+	{ .compatible = "ti,tas5751", .data = &tas5751_chip, },
 	{ .compatible = "ti,tas5733", .data = &tas5733_chip, },
 	{ }
 };
@@ -965,6 +1038,7 @@ static const struct i2c_device_id tas571x_i2c_id[] = {
 	{ "tas5717", (kernel_ulong_t) &tas5717_chip },
 	{ "tas5719", (kernel_ulong_t) &tas5717_chip },
 	{ "tas5721", (kernel_ulong_t) &tas5721_chip },
+	{ "tas5751", (kernel_ulong_t) &tas5751_chip },
 	{ "tas5733", (kernel_ulong_t) &tas5733_chip },
 	{ }
 };
