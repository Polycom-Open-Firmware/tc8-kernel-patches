From 46016d90bbf05c9ba19c48917f3b2945f82a7fa3 Mon Sep 17 00:00:00 2001
From: re <re@local>
Date: Sat, 9 May 2026 05:41:56 +0000
Subject: [PATCH 6/6] tc8 v0.2.2: lock-in clean panel driver + DT touchscreen

---
 arch/arm64/boot/dts/freescale/imx8mm-tc8.dts | 8 +++-----
 drivers/gpu/drm/panel/panel-poly-lcc.c       | 5 ++---
 2 files changed, 5 insertions(+), 8 deletions(-)

diff --git a/arch/arm64/boot/dts/freescale/imx8mm-tc8.dts b/arch/arm64/boot/dts/freescale/imx8mm-tc8.dts
index 223eb0a94..4ce5e6d1d 100644
--- a/arch/arm64/boot/dts/freescale/imx8mm-tc8.dts
+++ b/arch/arm64/boot/dts/freescale/imx8mm-tc8.dts
@@ -134,18 +134,16 @@ &i2c2 {
 
 	touchscreen@5d {
 		compatible = "goodix,gt9271";
-		reg = <0x5d>;	/* default GT9xx address when INT is HIGH at reset */
+		reg = <0x5d>;
 		pinctrl-names = "default";
 		pinctrl-0 = <&pinctrl_touch>;
 		interrupt-parent = <&gpio1>;
 		interrupts = <9 IRQ_TYPE_EDGE_FALLING>;
 		irq-gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>;
-		/* No reset-gpios — stock keeps it as INPUT, only reads value.
-		 * Pulsing it LOW kills the chip on TC8. */
-		/* Touch power comes from the panel driver holding reset deasserted */
+		reset-gpios = <&gpio2 3 GPIO_ACTIVE_LOW>;
 		touchscreen-size-x = <800>;
 		touchscreen-size-y = <1280>;
-	status = "okay";
+		status = "okay";
 	};
 
 	/* On-board EEPROMs (board ID + cert?). Stock has them as 1-0050,
diff --git a/drivers/gpu/drm/panel/panel-poly-lcc.c b/drivers/gpu/drm/panel/panel-poly-lcc.c
index efc842cc9..69abe63c8 100644
--- a/drivers/gpu/drm/panel/panel-poly-lcc.c
+++ b/drivers/gpu/drm/panel/panel-poly-lcc.c
@@ -146,9 +146,7 @@ static void poly_lcc_dcs_write_cmd(struct poly_lcc *ctx, u8 cmd, u8 value)
 
 static void poly_lcc_init_sequence(struct poly_lcc *ctx)
 {
-	/* Init disabled — DSI host not yet up during prepare(); commands
-	 * fail with -EINVAL. TODO: move to enable() or use samsung-dsim init
-	 * complete callback. */
+	/* no-op: rotation handled by userspace compositor */
 }
 
 static int poly_lcc_disable(struct drm_panel *panel)
@@ -263,6 +261,7 @@ static int poly_lcc_get_modes(struct drm_panel *panel,
 	connector->display_info.width_mm = mode->width_mm;
 	connector->display_info.height_mm = mode->height_mm;
 
+
 	return 1;
 }
 
