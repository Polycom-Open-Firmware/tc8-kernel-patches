 #include <net/dsa.h>
 
-#define REALTEK_HW_STOP_DELAY		25	/* msecs */
-#define REALTEK_HW_START_DELAY		100	/* msecs */
+#define REALTEK_HW_STOP_DELAY		100	/* msecs */
+#define REALTEK_HW_START_DELAY		500	/* msecs */
 
