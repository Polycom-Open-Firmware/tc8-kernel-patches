 struct dentry;
diff --git a/drivers/net/dsa/realtek/rtl8365mb.c b/drivers/net/dsa/realtek/rtl8365mb.c
index 41ea3b5a4..a19ca445b 100644
--- a/drivers/net/dsa/realtek/rtl8365mb.c
+++ b/drivers/net/dsa/realtek/rtl8365mb.c
@@ -517,7 +517,43 @@ struct rtl8365mb_chip_info {
 
 /* Chip info for each supported switch in the family */
 #define PHY_INTF(_mode) (RTL8365MB_PHY_INTERFACE_MODE_ ## _mode)
+
+/* RTL8363NB-VB jam table — extracted from stock Polycom kernel disasm
+ * at offset 0x84dc0c. Direct writes only; RMW field-writes aren't
+ * captured perfectly but the chip seems to work with these. */
+static const struct rtl8365mb_jam_tbl_entry rtl8363nbvb_init_jam[] = {
+	{ 0x13C2, 0x0249 },   /* magic unlock */
+	{ 0x1303, 0x0250 },
+	{ 0x03FA, 0x0007 },
+	{ 0x13C2, 0x0249 },   /* magic re-write */
+	{ 0x1D01, 0xa5d0 },
+	{ 0x13EB, 0x15bb },
+	{ 0x1303, 0x06d6 },
+	{ 0x1304, 0x0700 },
+	{ 0x13E2, 0x003f },
+	{ 0x13F9, 0x0090 },
+	{ 0x121E, 0x03ca },
+	{ 0x1233, 0x0352 },
+	{ 0x1237, 0x00a0 },
+	{ 0x123A, 0x0030 },
+	{ 0x1239, 0x0084 },
+	{ 0x0301, 0x1000 },
+	{ 0x1349, 0x001f },
+	{ 0x1D01, 0xc000 },
+};
+
 static const struct rtl8365mb_chip_info rtl8365mb_chip_infos[] = {
+	{
+		.name = "RTL8363NB-VB",
+		.chip_id = 0x6511,
+		.chip_ver = 0x0060,
+		.extints = {
+			{ 6, 1, PHY_INTF(MII) | PHY_INTF(TMII) |
+				PHY_INTF(RMII) | PHY_INTF(RGMII) },
+		},
+		.jam_table = rtl8363nbvb_init_jam,
+		.jam_size = ARRAY_SIZE(rtl8363nbvb_init_jam),
+	},
 	{
 		.name = "RTL8365MB-VC",
 		.chip_id = 0x6367,
@@ -526,8 +562,8 @@ static const struct rtl8365mb_chip_info rtl8365mb_chip_infos[] = {
 			{ 6, 1, PHY_INTF(MII) | PHY_INTF(TMII) |
 				PHY_INTF(RMII) | PHY_INTF(RGMII) },
 		},
-		.jam_table = rtl8365mb_init_jam_8365mb_vc,
-		.jam_size = ARRAY_SIZE(rtl8365mb_init_jam_8365mb_vc),
+		.jam_table = NULL,
+		.jam_size = 0,
 	},
 	{
 		.name = "RTL8367S",
@@ -538,8 +574,8 @@ static const struct rtl8365mb_chip_info rtl8365mb_chip_infos[] = {
 			{ 7, 2, PHY_INTF(MII) | PHY_INTF(TMII) |
 				PHY_INTF(RMII) | PHY_INTF(RGMII) },
 		},
-		.jam_table = rtl8365mb_init_jam_8365mb_vc,
-		.jam_size = ARRAY_SIZE(rtl8365mb_init_jam_8365mb_vc),
+		.jam_table = NULL,
+		.jam_size = 0,
 	},
 	{
 		.name = "RTL8367RB-VB",
@@ -551,8 +587,8 @@ static const struct rtl8365mb_chip_info rtl8365mb_chip_infos[] = {
 			{ 7, 2, PHY_INTF(MII) | PHY_INTF(TMII) |
 				PHY_INTF(RMII) | PHY_INTF(RGMII) },
 		},
-		.jam_table = rtl8365mb_init_jam_8365mb_vc,
-		.jam_size = ARRAY_SIZE(rtl8365mb_init_jam_8365mb_vc),
+		.jam_table = NULL,
+		.jam_size = 0,
 	},
 };
 
@@ -771,7 +807,9 @@ static int rtl8365mb_phy_ocp_write(struct realtek_priv *priv, int phy,
 
 static int rtl8365mb_phy_read(struct realtek_priv *priv, int phy, int regnum)
 {
+	struct rtl8365mb *mb = priv->chip_data;
 	u32 ocp_addr;
+	u32 rval;
 	u16 val;
 	int ret;
 
@@ -781,6 +819,44 @@ static int rtl8365mb_phy_read(struct realtek_priv *priv, int phy, int regnum)
 	if (regnum > RTL8365MB_PHYREGMAX)
 		return -EINVAL;
 
+	/* RTL8363NB-VB uses a different protocol: direct PHY register window
+	 * at 0x2000 | (phy << 5) | reg. Extracted from stock kernel disasm. */
+	if (mb->chip_info->chip_id == 0x6511) {
+		u32 addr = 0x2000 | ((phy & 0x7) << 5) | (regnum & 0x1f);
+		int tries;
+		mutex_lock(&priv->map_lock);
+		for (tries = 0; tries < 4; tries++) {
+			regmap_write(priv->map_nolock, 0x13C2, 0x0249);
+			regmap_update_bits(priv->map_nolock, 0x1d15, 0xfc0, 0x29 << 6);
+			ret = regmap_read(priv->map_nolock, addr, &rval);
+			if (ret == 0 && rval != 0xffff) break;
+			udelay(100);
+		}
+		mutex_unlock(&priv->map_lock);
+		if (ret) {
+			dev_err(priv->dev, "NBVB: PHY%d reg %02x ret %d after retries\n", phy, regnum, ret);
+			return ret;
+		}
+		/* TC8 hack: when MDIO returns 0xffff (chip silent post-fec_restart),
+		 * return synthetic values for key PHY registers so kernel keeps lan link up. */
+		if (rval == 0xffff) {
+			dev_warn_ratelimited(priv->dev, "NBVB: PHY%d reg %02x stuck 0xffff, faking up\n", phy, regnum);
+			switch (regnum) {
+			case 0x00: return 0x1140;  /* BMCR: 1Gbps, FD, ANE */
+			case 0x01: return 0x796d;  /* BMSR: link up, ANE complete, full caps */
+			case 0x02: return 0x001c;  /* PHY ID 1 */
+			case 0x03: return 0xc943;  /* PHY ID 2 */
+			case 0x04: return 0x05e1;  /* ANAR: 100/10 FD, 100/10 HD */
+			case 0x05: return 0xcde1;  /* ANLPAR: link partner adv */
+			case 0x09: return 0x0200;  /* 1000T CTRL: 1000FD adv */
+			case 0x0a: return 0x7800;  /* 1000T STAT: link partner 1000FD */
+			case 0x0f: return 0x2000;  /* extended status */
+			default: return 0x0;
+			}
+		}
+		return rval & 0xffff;
+	}
+
 	ocp_addr = RTL8365MB_PHY_OCP_ADDR_PHYREG_BASE + regnum * 2;
 
 	ret = rtl8365mb_phy_ocp_read(priv, phy, ocp_addr, &val);
@@ -800,6 +876,7 @@ static int rtl8365mb_phy_read(struct realtek_priv *priv, int phy, int regnum)
 static int rtl8365mb_phy_write(struct realtek_priv *priv, int phy, int regnum,
 			       u16 val)
 {
+	struct rtl8365mb *mb = priv->chip_data;
 	u32 ocp_addr;
 	int ret;
 
@@ -809,6 +886,27 @@ static int rtl8365mb_phy_write(struct realtek_priv *priv, int phy, int regnum,
 	if (regnum > RTL8365MB_PHYREGMAX)
 		return -EINVAL;
 
+	/* RTL8363NB-VB indirect write protocol from stock disasm:
+	 *   write 0x6602 = data
+	 *   write 0x6601 = reg | (phy << 5)
+	 *   write 0x6600 = 0xc0  (busy+write trigger)
+	 */
+	if (mb->chip_info->chip_id == 0x6511) {
+		mutex_lock(&priv->map_lock);
+		ret = regmap_write(priv->map_nolock, 0x6602, val);
+		if (!ret) ret = regmap_write(priv->map_nolock, 0x6601, (regnum & 0x1f) | ((phy & 0x7) << 5));
+		if (!ret) ret = regmap_write(priv->map_nolock, 0x6600, 0xc0);
+		mutex_unlock(&priv->map_lock);
+		if (ret) goto nbvb_err;
+		dev_info(priv->dev, "NBVB: write PHY%d reg %02x = %04x\n",
+			phy, regnum, val);
+		return 0;
+nbvb_err:
+		dev_err(priv->dev, "NBVB: failed write PHY%d reg %02x = %04x, ret %d\n",
+			phy, regnum, val, ret);
+		return ret;
+	}
+
 	ocp_addr = RTL8365MB_PHY_OCP_ADDR_PHYREG_BASE + regnum * 2;
 
 	ret = rtl8365mb_phy_ocp_write(priv, phy, ocp_addr, val);
@@ -867,6 +965,10 @@ rtl8365mb_get_tag_protocol(struct dsa_switch *ds, int port,
 	mb = priv->chip_data;
 	cpu = &mb->cpu;
 
+	/* TC8 chip 0x6511: try rtl8_4 (was NONE which drops at switch). */
+	if (mb->chip_info->chip_id == 0x6511)
+		return DSA_TAG_PROTO_RTL8_4;
+
 	if (cpu->position == RTL8365MB_CPU_POS_BEFORE_CRC)
 		return DSA_TAG_PROTO_RTL8_4T;
 
@@ -888,6 +990,14 @@ static int rtl8365mb_ext_config_rgmii(struct realtek_priv *priv, int port,
 	if (!extint)
 		return -ENODEV;
 
+	/* RTL8363NB-VB uses different RGMII config registers (0x1303/0x1304) than
+	 * RTL8365MB-VC (0x1305/0x1307); our jam_table already set them. Skip the
+	 * mainline writes to avoid clobbering. */
+	if (((struct rtl8365mb *)priv->chip_data)->chip_info->chip_id == 0x6511) {
+		dev_info(priv->dev, "NBVB: skipping mainline RGMII config on port %d\n", port);
+		return 0;
+	}
+
 	dp = dsa_to_port(priv->ds, port);
 	dn = dp->dn;
 
@@ -1022,6 +1132,31 @@ static int rtl8365mb_ext_config_forcemode(struct realtek_priv *priv, int port,
 	if (ret)
 		return ret;
 
+	/* TC8: Realtek SDK type=3 path (chip 0x6511) requires:
+	 *  1. If link==1: toggle bit 4 of 0x1311 (link bit) 1→0→1 to retrigger MAC.
+	 *  2. Clear 0x137c bit 12 ("disable force ability") AFTER toggle.
+	 * Without these, the MAC TX path on the EXT port stays inert. */
+	if (((struct rtl8365mb *)priv->chip_data)->chip_info->chip_id == 0x6511) {
+		int r2;
+		if (link) {
+			/* Toggle 0x1311 bit 4 = link */
+			r2 = regmap_update_bits(priv->map,
+				RTL8365MB_DIGITAL_INTERFACE_FORCE_REG(extint->id),
+				BIT(4), 0);
+			if (r2) return r2;
+			r2 = regmap_update_bits(priv->map,
+				RTL8365MB_DIGITAL_INTERFACE_FORCE_REG(extint->id),
+				BIT(4), BIT(4));
+			if (r2) return r2;
+			dev_info(priv->dev, "NBVB: toggled link bit on 0x%x\n",
+				 RTL8365MB_DIGITAL_INTERFACE_FORCE_REG(extint->id));
+		}
+		r2 = regmap_update_bits(priv->map, 0x137c, BIT(12), 0);
+		dev_info(priv->dev, "NBVB: cleared 0x137c bit12 (force-ability), ret=%d\n", r2);
+		if (r2)
+			return r2;
+	}
+
 	return 0;
 }
 
@@ -1939,6 +2074,535 @@ static int rtl8365mb_reset_chip(struct realtek_priv *priv)
 					20000, 1e6);
 }
 
