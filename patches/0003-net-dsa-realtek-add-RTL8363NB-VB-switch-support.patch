+static int nbvb_apply_stock_replay(struct realtek_priv *priv)
+{
+	int i, ret;
+	dev_info(priv->dev, "NBVB: applying %zu stock-captured register values\n",
+		 ARRAY_SIZE(nbvb_stock_replay));
+	for (i = 0; i < ARRAY_SIZE(nbvb_stock_replay); i++) {
+		ret = regmap_write(priv->map,
+				   nbvb_stock_replay[i].reg,
+				   nbvb_stock_replay[i].val);
+		if (ret) {
+			dev_err(priv->dev, "NBVB: stock replay[%d] reg 0x%x val 0x%x failed: %d\n",
+				i, nbvb_stock_replay[i].reg,
+				nbvb_stock_replay[i].val, ret);
+			return ret;
+		}
+	}
+	dev_info(priv->dev, "NBVB: stock replay done\n");
+	return 0;
+}
