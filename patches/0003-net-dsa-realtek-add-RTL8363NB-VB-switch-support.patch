+static int nbvb_apply_ext_rgmii_setup(struct realtek_priv *priv)
+{
+	/* Reproduce Realtek SDK setAsicPortExtMode(id=1, mode=EXT_RGMII) for
+	 * type=3 chip 0x6511. Mainline rtl8365mb does not include these
+	 * register touches; without them the EXT MAC TX path is inert. */
+	int ret;
+
+	/* Disable LED IO mux on EXT1 pins (PARA_LED_IO_EN1/2/3 = 0) */
+	ret = regmap_write(priv->map, 0x1b33, 0);
+	if (ret) return ret;
+	ret = regmap_write(priv->map, 0x1b24, 0);
+	if (ret) return ret;
+	ret = regmap_write(priv->map, 0x1b25, 0);
+	if (ret) return ret;
+
+	/* 0x1303 ext1 control: bit9=1, bit6=1, bit4=1, bit1=0 */
+	ret = regmap_update_bits(priv->map, 0x1303, BIT(9) | BIT(6) | BIT(4) | BIT(1),
+				 BIT(9) | BIT(6) | BIT(4));
+	if (ret) return ret;
+
+	/* 0x1307 ext1 RGMII delay: bit3=1; bits[2:0]=0 */
+	ret = regmap_update_bits(priv->map, 0x1307, BIT(3) | 0x7, BIT(3));
+	if (ret) return ret;
+
+	/* 0x13f9: bits[5:3]=0; bits[10:8]=4 */
+	ret = regmap_update_bits(priv->map, 0x13f9, 0x38, 0);
+	if (ret) return ret;
+	ret = regmap_update_bits(priv->map, 0x13f9, 0x700, 4 << 8);
+	if (ret) return ret;
+
+	/* 0x1304 mode bits[14:12]=4 */
+	ret = regmap_update_bits(priv->map, 0x1304, 0x7000, 4 << 12);
+	if (ret) return ret;
+
+	dev_info(priv->dev, "NBVB: applied SDK setAsicPortExtMode(id=1, RGMII) writes\n");
+	return 0;
+}
