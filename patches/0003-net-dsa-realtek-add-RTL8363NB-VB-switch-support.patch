+static int nbvb_apply_8051_firmware(struct realtek_priv *priv)
+{
+	int i, ret;
+	dev_info(priv->dev, "NBVB: loading %zu-byte 8051 firmware to 0xe000+\n",
+		 sizeof(nbvb_8051_firmware));
+	for (i = 0; i < sizeof(nbvb_8051_firmware); i++) {
+		ret = regmap_write(priv->map, 0xe000 + i,
+				   nbvb_8051_firmware[i]);
+		if (ret) {
+			dev_err(priv->dev, "NBVB: 8051 fw byte %d (reg 0x%x) failed: %d\n",
+				i, 0xe000 + i, ret);
+			return ret;
+		}
+	}
+	dev_info(priv->dev, "NBVB: 8051 firmware loaded successfully\n");
+	return 0;
+}
