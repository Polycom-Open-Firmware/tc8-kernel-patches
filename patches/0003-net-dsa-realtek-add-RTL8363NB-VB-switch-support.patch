+static int nbvb_apply_phy_ocp_patches(struct realtek_priv *priv)
+{
+	u32 orig_1d01;
+	int i, ret;
+
+	/* Save 0x1D01, then set broadcast-port-enable + phy_id=0:
+	 *   new = (orig & 0xFFE0) | 0x3BE0 (per stock disasm at 0x84e2dc) */
+	ret = regmap_read(priv->map, 0x1D01, &orig_1d01);
+	if (ret) return ret;
+	ret = regmap_write(priv->map, 0x1D01, (orig_1d01 & 0xFFE0) | 0x3BE0);
+	if (ret) return ret;
+
+	dev_info(priv->dev, "NBVB: applying %d-entry PHY OCP patch table to PHY 0\n",
+		 (int)ARRAY_SIZE(nbvb_phy_ocp_patch));
+
+	for (i = 0; i < ARRAY_SIZE(nbvb_phy_ocp_patch); i++) {
+		ret = nbvb_phy_ocp_write(priv, 0,
+					 nbvb_phy_ocp_patch[i][0],
+					 nbvb_phy_ocp_patch[i][1]);
+		if (ret) {
+			dev_err(priv->dev, "NBVB: patch[%d] failed: %d\n", i, ret);
+			break;
+		}
+	}
+
+	/* Restore 0x1D01 (broadcast disable, restore phy_id) */
+	regmap_write(priv->map, 0x1D01, orig_1d01);
+
+	dev_info(priv->dev, "NBVB: PHY OCP patches done (last i=%d)\n", i);
+
+	/* SDK _init_8367c end-of-init RMW writes (we missed these in jam_table
+	 * because they're per-bit, not direct writes). */
+	regmap_update_bits(priv->map, 0x18e0, BIT(0), 0);            /* clear bit 0 */
+	regmap_update_bits(priv->map, 0x122b, BIT(14), BIT(14));     /* set bit 14 */
+	regmap_update_bits(priv->map, 0x1305, 0xC000, 0xC000);       /* bits 15:14 = 3 */
+	dev_info(priv->dev, "NBVB: applied SDK end-of-init RMW writes (0x18e0/0x122b/0x1305)\n");
+
+	return ret;
+}
