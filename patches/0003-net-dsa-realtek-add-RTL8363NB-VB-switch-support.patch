+static int nbvb_phy_ocp_write(struct realtek_priv *priv, int phy, u32 ocp_addr, u16 val)
+{
+	/* Stock's setAsicPHYOCPReg using direct PHY-window method.
+	 * Compute OCP prefix (top 6 bits >> 10), set bits[11:6] of 0x1D15,
+	 * compute target reg = 0x2000 | (ocpAddr9_6 << 8) | (phy << 5) | ocpAddr5_1,
+	 * then write target = ocp_data via stock indirect (0x6602/0x6601/0x6600=0xc0). */
+	u32 prefix = (ocp_addr >> 10) & 0x3F;
+	u32 ocp_9_6 = (ocp_addr >> 6) & 0x0F;
+	u32 ocp_5_1 = (ocp_addr >> 1) & 0x1F;
+	u32 target = 0x2000 | (ocp_9_6 << 8) | ((phy & 0x7) << 5) | ocp_5_1;
+	int ret;
+
+	mutex_lock(&priv->map_lock);
+	/* Set OCP prefix in 0x1D15 bits[11:6] */
+	ret = regmap_update_bits(priv->map_nolock, 0x1D15, 0xFC0, prefix << 6);
+	if (ret) goto out;
+	/* Stock indirect WRITE protocol */
+	ret = regmap_write(priv->map_nolock, 0x6602, val);
+	if (ret) goto out;
+	ret = regmap_write(priv->map_nolock, 0x6601, target & 0x1FFF);
+	if (ret) goto out;
+	ret = regmap_write(priv->map_nolock, 0x6600, 0xc0 | ((target >> 13) & 0xF));
+out:
+	mutex_unlock(&priv->map_lock);
+	return ret;
+}
